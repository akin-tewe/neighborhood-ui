{
  "name": "@neighborhood/ui",
  "version": "0.1.0",
  "description": "Neighborhood Design System — components and tokens for building interfaces with warmth, motion, and personality.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens.css": "./src/tokens.css"
  },
  "files": [
    "dist",
    "src/tokens.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@heroicons/react": "^2.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@heroicons/react": "^2.2.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "sideEffects": false,
  "keywords": [
    "design-system",
    "react",
    "components",
    "tokens",
    "neighborhood"
  ]
}
